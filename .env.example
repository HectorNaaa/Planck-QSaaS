# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# Database Configuration
POSTGRES_URL=postgresql://user:password@host:port/dbname
POSTGRES_URL_NON_POOLING=postgresql://user:password@host:port/dbname
POSTGRES_PRISMA_URL=postgresql://user:password@pooler:port/dbname
POSTGRES_HOST=host
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DATABASE=database

# Supabase Service Role (Server-side only)
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
SUPABASE_JWT_SECRET=your_jwt_secret_here

# Stripe Configuration
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_key_here
STRIPE_SECRET_KEY=sk_test_your_key_here

# Vercel Configuration (Auto-populated by Vercel)
# VERCEL_OIDC_TOKEN=auto_generated
